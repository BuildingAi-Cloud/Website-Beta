# BuildingSync R1 — environment template
# Copy to .env.local for dev. Never commit a populated .env*.

# --- App ---
APP_BASE_URL=http://localhost:3000
ADMIN_HOST=admin.buildingsync.app

# --- Supabase --- Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Database --- Settings → Database → Connection string
# DATABASE_URL = pooled (port 6543, transaction mode) — for runtime + Vercel
# DIRECT_URL   = direct (port 5432) — for `prisma migrate`
DATABASE_URL=postgresql://postgres.__PROJECT_REF__:__DB_PASSWORD__@aws-0-__REGION__.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:__DB_PASSWORD__@db.__PROJECT_REF__.supabase.co:5432/postgres

# --- Stripe --- Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend --- resend.com/api-keys (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=BuildingSync <noreply@buildingsync.app>
